# Variables del gateway de la Raspberry. Copiá este archivo a "gateway.env" y completá los valores.
# El servicio systemd lo lee con EnvironmentFile=; en una shell, "set -a; . gateway.env; set +a".

# URL pública HTTPS del backend (Railway). SIN barra final.
API_BASE=https://tu-backend.up.railway.app

# Opcional. Solo si el backend tiene APP_CONFIG_API_KEY seteada Y este gateway llegara a publicar
# configuración. Publicar mediciones (POST /api/measurements) NO la necesita: dejala vacía.
CONFIG_API_KEY=
