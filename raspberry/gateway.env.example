# Variables de entorno del gateway. Copiar a gateway.env y ajustar.
# Todas tienen default sensato en gateway.py; solo overrideas lo que necesites.

# URL publica del backend (sin barra final).
API_BASE=https://plc-control-backend-production.up.railway.app

# PLC (OpenPLC como esclavo Modbus TCP en la misma Raspberry).
PLC_HOST=127.0.0.1
PLC_PORT=502

# Pines BCM. DHT22 en GPIO4 (pin fisico 7). Rele en GPIO14 (pin fisico 8), activo-alto.
DHT_GPIO=4
RELAY_GPIO=14
RELAY_ACTIVE_LOW=0

# Piso de intervalo de publicacion (s). El real lo marca la config del backend.
MIN_INTERVAL=4
